# ------------------------------------------------------------------
# Nexkara Canvas — environment (copy to .env for docker-compose)
# ------------------------------------------------------------------

# --- Postgres ---
POSTGRES_USER=nexkara
POSTGRES_PASSWORD=nexkara_dev_pw
POSTGRES_DB=nexkara
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Backend ---
# CHANGE in any non-dev environment. Generate with: openssl rand -hex 32
JWT_SECRET=dev-only-change-me-super-secret-key
SESSION_TTL_MINUTES=60
DEVICE_TRUST_DAYS=30
OTP_TTL_SECONDS=600
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_MAX_ATTEMPTS=5
# dev | production. In production the API refuses to boot with insecure defaults.
ENV=dev
# Cookies: set to true behind HTTPS (Caddy in prod). false for plain-http local dev.
COOKIE_SECURE=false
FRONTEND_ORIGIN=http://localhost:3000

# --- Prototype sandbox (separate-origin rendering) ---
# Empty in dev (same-origin blob). In production set to an isolated host that
# serves ONLY /s/* (see docs/deployment.md), e.g. https://sandbox.canvas.example.com
SANDBOX_ORIGIN=
SANDBOX_TOKEN_TTL_MINUTES=30

# --- Seed admin ---
SEED_ADMIN_EMAIL=hammad@medzah.com
SEED_ADMIN_NAME=Hammad Hasany
SEED_ADMIN_PASSWORD=admin123

# --- Object storage ---
# "minio" (docker-compose default) or "local" (filesystem, no MinIO needed for dev).
STORAGE_BACKEND=minio
LOCAL_STORAGE_DIR=./storage_data

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=nexkara
MINIO_SECRET_KEY=nexkara_dev_pw
MINIO_BUCKET=prototypes
MINIO_SECURE=false
# Browser-facing host for presigned URLs (via Caddy in prod). Dev: localhost.
MINIO_PUBLIC_ENDPOINT=localhost:9000

# --- Uploads ---
MAX_UPLOAD_BYTES=5242880

# --- Mail (dev: console. prod: real SMTP) ---
MAIL_BACKEND=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@nexkara.com

# --- Frontend ---
# Browser -> API base. In dev the Next.js rewrite proxies /api to the backend.
NEXT_PUBLIC_API_BASE=/api
# Server-side (middleware) -> API base inside the docker network.
INTERNAL_API_BASE=http://api:8000

# --- Production domains (used by Caddyfile.prod / docker-compose.prod.yml) ---
# The app's public domain and an isolated sandbox subdomain for prototype rendering.
APP_DOMAIN=canvas.example.com
SANDBOX_DOMAIN=sandbox.canvas.example.com
